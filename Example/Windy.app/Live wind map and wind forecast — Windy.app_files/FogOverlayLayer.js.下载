const createFogOverlayLayer = () => {
    const layer = Object.assign({}, windyAppLayer);

    layer.id = 'fog-overlay';
    layer.model = 'ICONGLOBAL';
    layer.dataType = 'fog';
    layer.url = 'https://api.windyapp.co/v10/tiles';
    layer.enabled = false;
    layer.opacity = 1.0;
    layer.patternSrc = '/widget3/img/fog_pattern.svg';
    layer.patternScale = [192.0, 192.0];
    layer.dataCanvas = [];
    layer.dataCtx = false;
    layer.images = {};
    layer.loading = function() {
        return Object.entries(this.loading).length > 0;
    };
    layer.loaded = {};
    layer.drawn = {};
    layer.dataZoom = 0;
    layer.prevDataZoom = 0;
    layer.defaultDataZoom = 3;
    layer.dataZooms = [0, 0, 1, 2, 3];
    layer.texTimeout = false;
    layer.patternReady = false;
    layer._moveBound = false;

    layer.setType = () => {};
    layer.setModel = () => {};
    layer.applyColors = () => {};
    layer.getColors = () => new Uint8Array([0, 0, 0, 0]);

    layer.clearTileCache = function() {
        this.loaded = {};
        this.drawn = {};
        Object.entries(this.images).forEach((entry) => {
            const idx = entry[0];
            this.images[idx].src = '';
            delete this.images[idx];
            if (this.loading[idx]) {
                delete this.loading[idx];
                this.delLoading();
            }
        });
    };

    layer.setEnabled = function(enabled) {
        this.enabled = !!enabled;
        if (this.enabled) {
            this.requestData();
        }
        if (this.map && typeof this.map.triggerRepaint === 'function') {
            this.map.triggerRepaint();
        }
    };

    layer.requestData = function() {
        if (!this.enabled || !this.map || !this.leafletMap || !this.setCallback || !this.releaseCallback) return;
        this.setCallback('fogOverlayLayer', () => this.setData());

        this.dataCtx = this.dataCanvas[this.getDataZoom()].getContext('2d');
        const b = this.leafletMap.getBounds(),
            sw = b.getSouthWest ? b.getSouthWest() : (b._sw || b._southWest),
            ne = b.getNorthEast ? b.getNorthEast() : (b._ne || b._northEast),
            z = this.getDataZoom(),
            grid = Math.pow(2, z),
            tileHeight = 180 / grid,
            tilePad = 1,
            minY = Math.max(0, Math.floor((90 - ne.lat) / tileHeight) - tilePad),
            maxY = Math.min(grid - 1, Math.floor((90 - sw.lat) / tileHeight) + tilePad),
            mult = 1;

        let minLng, maxLng, minX, maxX, sides;

        if (!this.dragging) {
            this.cancelLoading();
        }

        if (this.getDataZoom() !== this.prevDataZoom) {
            this.clearDataCanvases();
            this.prevDataZoom = this.getDataZoom();
        }

        let toSetData = false;
        const bindActiveTileHandlers = (idx, x, y) => {
            this.images[idx].onload = () => {
                delete this.loading[idx];
                this.delLoading();
                if (!this.loading()) {
                    this.releaseCallback('fogOverlayLayer');
                }
                this.loaded[idx] = true;
                if (idx.split('/')[0] == this.ts) {
                    this.dataCtx.drawImage(this.images[idx], 360 * x * mult, 180 * y * mult, 360 * mult, 180 * mult);
                    this.drawn[idx] = true;
                }
            };
            this.images[idx].onerror = () => {
                if (this.loading[idx]) {
                    delete this.loading[idx];
                    this.delLoading();
                }
                delete this.images[idx];
                delete this.loaded[idx];
                if (!this.loading()) {
                    this.releaseCallback('fogOverlayLayer');
                }
            };
        };
        for (let y = minY; y <= maxY; y++) {
            sides = sw.lng < -180 || ne.lng > 180;
            for (let side = 0; side <= sides; side++) {
                if (side === 0 && sw.lng < -180) {
                    minLng = 180 - (-sw.lng - 180);
                    maxLng = 180;
                } else if (side === 1 && ne.lng > 180) {
                    minLng = -180;
                    maxLng = -180 + (ne.lng - 180);
                } else {
                    minLng = Math.max(-180, sw.lng);
                    maxLng = Math.min(180, ne.lng);
                }

                minX = Math.max(0, Math.min(grid - 1, Math.floor((minLng + 180) / 360 * grid) - tilePad));
                maxX = Math.max(0, Math.min(grid - 1, Math.floor((maxLng + 180) / 360 * grid) + tilePad));

                for (let x = minX; x <= maxX; x++) {
                    const idx = this.ts + '/' + z + '/' + x + '/' + y;
                    if (this.images[idx]) {
                        if (this.loaded[idx] && !this.drawn[idx]) {
                            this.dataCtx.drawImage(this.images[idx], 360 * x * mult, 180 * y * mult, 360 * mult, 180 * mult);
                            toSetData = true;
                            this.drawn[idx] = true;
                        } else if (!this.loaded[idx] && !this.loading[idx]) {
                            this.addLoading();
                            this.loading[idx] = true;
                            bindActiveTileHandlers(idx, x, y);
                            if (this.images[idx].complete) {
                                if (this.images[idx].naturalWidth > 0) {
                                    this.images[idx].onload();
                                } else {
                                    this.images[idx].onerror();
                                }
                            }
                        }
                    } else {
                        this.addLoading();
                        this.images[idx] = new Image();
                        this.images[idx].crossOrigin = 'anonymous';
                        bindActiveTileHandlers(idx, x, y);
                        this.images[idx].src = `${this.url}/${this.model}/${this.dataType}/${this.ts}/${z}/${x}/${y}`;
                        this.loading[idx] = true;
                    }
                }
            }
        }

        if (toSetData && !this.loading()) {
            setTimeout(() => {
                this.releaseCallback('fogOverlayLayer');
            }, this.playing ? 250 : 0);
        }
    };

    layer.setData = function() {
        clearTimeout(this.texTimeout);
        this.texTimeout = setTimeout(() => {
            if (this.gl && this.enabled) {
                this.gl.useProgram(this.program);
                this.gl.uniform1i(this.u_imageLoc, 0);
                this.gl.activeTexture(this.gl.TEXTURE0);
                this.gl.bindTexture(this.gl.TEXTURE_2D, this.texData);
                this.gl.texImage2D(this.gl.TEXTURE_2D, 0, this.gl.RGBA, this.gl.RGBA, this.gl.UNSIGNED_BYTE, this.dataCanvas[this.getDataZoom()]);
                this.map.triggerRepaint();
            }
        }, 20);
    };

    layer.onAdd = function(map, gl) {
        this.gl = gl;
        this.map = map;

        const vertexSource = `
        #define PI 3.14159265358
        #define PI4 0.78539816339
        uniform float latFrom;
        uniform float latLen;
        attribute float vertexId;
        varying vec2 v_texcoord;
        uniform mat4 u_matrix;

        void main() {
            float lat = floor(vertexId / 2. - 90. + latFrom);
            float y_tex = (360. / PI) * (atan(exp(2. * PI * lat / 180.)) - PI4) / 90.;
            float x = 1. - mod(vertexId, 2.);
            float y = 1. - floor(vertexId / 2.) / 180.;
            gl_Position = u_matrix * vec4(x, y, 0, 1);
            v_texcoord = vec2(x, 1. - (y_tex + 1.) / 2.);
        }
        `;

        const fragmentSource = `
        precision mediump float;
        uniform sampler2D u_image;
        uniform sampler2D u_pattern;
        uniform float u_opacity;
        uniform vec2 u_patternScale;
        uniform vec2 u_patternOffset;
        uniform float u_viewportHeight;
        uniform vec2 u_dataTexel;
        varying vec2 v_texcoord;

        void main() {
            vec4 dataCenter = texture2D(u_image, v_texcoord);
            vec4 data = dataCenter * 0.5;
            data += texture2D(u_image, v_texcoord + vec2(u_dataTexel.x, 0.0)) * 0.125;
            data += texture2D(u_image, v_texcoord - vec2(u_dataTexel.x, 0.0)) * 0.125;
            data += texture2D(u_image, v_texcoord + vec2(0.0, u_dataTexel.y)) * 0.125;
            data += texture2D(u_image, v_texcoord - vec2(0.0, u_dataTexel.y)) * 0.125;

            float coverage = smoothstep(0.55, 0.84, data.a);
            float density = smoothstep(0.08, 0.72, data.r);
            float mask = coverage * density;
            if (mask <= 0.01) {
                gl_FragColor = vec4(0.0);
                return;
            }

            vec2 screenCoord = vec2(gl_FragCoord.x, u_viewportHeight - gl_FragCoord.y);
            vec2 patternUV = fract((screenCoord + u_patternOffset) / u_patternScale);
            vec4 pattern = texture2D(u_pattern, patternUV);
            float lineMask = smoothstep(0.06, 0.78, pattern.a);

            float fillAlpha = mask * 0.32 * u_opacity;
            float lineAlpha = lineMask * mask * 0.45 * u_opacity;
            float outAlpha = max(fillAlpha, lineAlpha) * smoothstep(0.02, 0.22, mask);

            vec3 fillColor = vec3(0.75, 0.81, 0.73);
            vec3 lineColor = vec3(0.965, 0.99, 1.0);
            vec3 rgb = mix(fillColor, lineColor, lineMask);

            gl_FragColor = vec4(rgb, outAlpha);
        }
        `;

        const vertexShader = gl.createShader(gl.VERTEX_SHADER);
        gl.shaderSource(vertexShader, vertexSource);
        gl.compileShader(vertexShader);

        const fragmentShader = gl.createShader(gl.FRAGMENT_SHADER);
        gl.shaderSource(fragmentShader, fragmentSource);
        gl.compileShader(fragmentShader);

        this.program = gl.createProgram();
        gl.attachShader(this.program, vertexShader);
        gl.attachShader(this.program, fragmentShader);
        gl.linkProgram(this.program);

        this.vertexIdLoc = gl.getAttribLocation(this.program, 'vertexId');
        this.u_imageLoc = gl.getUniformLocation(this.program, 'u_image');
        this.u_patternLoc = gl.getUniformLocation(this.program, 'u_pattern');
        this.u_matrixLoc = gl.getUniformLocation(this.program, 'u_matrix');
        this.latFromLoc = gl.getUniformLocation(this.program, 'latFrom');
        this.latLenLoc = gl.getUniformLocation(this.program, 'latLen');
        this.u_opacityLoc = gl.getUniformLocation(this.program, 'u_opacity');
        this.u_patternScaleLoc = gl.getUniformLocation(this.program, 'u_patternScale');
        this.u_patternOffsetLoc = gl.getUniformLocation(this.program, 'u_patternOffset');
        this.u_viewportHeightLoc = gl.getUniformLocation(this.program, 'u_viewportHeight');
        this.u_dataTexelLoc = gl.getUniformLocation(this.program, 'u_dataTexel');

        const latFrom = 0;
        const latLen = 180;
        const arrLen = latLen * 2 + 2;
        this.idBuffer = gl.createBuffer();
        this.vertexIds = new Float32Array(Array.from({ length: arrLen }, (_, i) => i + latFrom * 2));
        gl.bindBuffer(gl.ARRAY_BUFFER, this.idBuffer);
        gl.bufferData(gl.ARRAY_BUFFER, this.vertexIds, gl.STATIC_DRAW);
        gl.enableVertexAttribArray(this.vertexIdLoc);
        gl.vertexAttribPointer(this.vertexIdLoc, 1, gl.FLOAT, false, 0, 0);

        gl.useProgram(this.program);
        gl.uniform1f(this.latFromLoc, latFrom);
        gl.uniform1f(this.latLenLoc, latLen);

        this.texData = gl.createTexture();
        gl.activeTexture(gl.TEXTURE0);
        gl.bindTexture(gl.TEXTURE_2D, this.texData);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, new Uint8Array([0, 0, 0, 0]));
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.CLAMP_TO_EDGE);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);

        this.texPattern = gl.createTexture();
        gl.activeTexture(gl.TEXTURE1);
        gl.bindTexture(gl.TEXTURE_2D, this.texPattern);
        gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, 1, 1, 0, gl.RGBA, gl.UNSIGNED_BYTE, new Uint8Array([0, 0, 0, 0]));
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_S, gl.REPEAT);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_WRAP_T, gl.REPEAT);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MIN_FILTER, gl.LINEAR_MIPMAP_LINEAR);
        gl.texParameteri(gl.TEXTURE_2D, gl.TEXTURE_MAG_FILTER, gl.LINEAR);

        const patternImage = new Image();
        patternImage.crossOrigin = 'anonymous';
        patternImage.onload = () => {
            const patternCanvas = document.createElement('canvas');
            patternCanvas.width = 128;
            patternCanvas.height = 128;
            const patternCtx = patternCanvas.getContext('2d');
            const pattern = patternCtx.createPattern(patternImage, 'repeat');
            patternCtx.clearRect(0, 0, patternCanvas.width, patternCanvas.height);
            patternCtx.fillStyle = pattern;
            patternCtx.fillRect(0, 0, patternCanvas.width, patternCanvas.height);

            gl.activeTexture(gl.TEXTURE1);
            gl.bindTexture(gl.TEXTURE_2D, this.texPattern);
            gl.texImage2D(gl.TEXTURE_2D, 0, gl.RGBA, gl.RGBA, gl.UNSIGNED_BYTE, patternCanvas);
            gl.generateMipmap(gl.TEXTURE_2D);
            this.patternReady = true;
            if (this.enabled && this.map && typeof this.map.triggerRepaint === 'function') {
                this.map.triggerRepaint();
            }
        };
        patternImage.src = this.patternSrc;

        this.dataCanvasSize = {
            0: [720, 360],
            1: [720, 360],
            2: [1440, 720],
            3: [2880, 1440]
        };
        const dataCanvas1 = this.createCanvas(720, 360);
        this.dataCanvas = [
            dataCanvas1,
            dataCanvas1,
            this.createCanvas(1440, 720),
            this.createCanvas(2880, 1440)
        ];

        if (!this._moveBound) {
            this._moveBound = true;
            this.map.on('move', () => {
                if (this.enabled) {
                    this.requestData();
                }
            });
        }

        if (this.enabled) {
            this.requestData();
        }
    };

    layer.render = function(gl, matrix) {
        if (!this.enabled || !this.patternReady) return;

        gl.useProgram(this.program);
        gl.bindBuffer(gl.ARRAY_BUFFER, this.idBuffer);
        gl.enableVertexAttribArray(this.vertexIdLoc);
        gl.vertexAttribPointer(this.vertexIdLoc, 1, gl.FLOAT, false, 0, 0);

        gl.uniform1i(this.u_imageLoc, 0);
        gl.activeTexture(gl.TEXTURE0);
        gl.bindTexture(gl.TEXTURE_2D, this.texData);

        gl.uniform1i(this.u_patternLoc, 1);
        gl.activeTexture(gl.TEXTURE1);
        gl.bindTexture(gl.TEXTURE_2D, this.texPattern);

        const patternScaleX = this.patternScale[0];
        const patternScaleY = this.patternScale[1];
        let patternOffsetX = 0.0;
        let patternOffsetY = 0.0;
        if (this.map && typeof this.map.project === 'function') {
            const mapCanvas = this.map.getCanvas && this.map.getCanvas();
            const pixelRatioX = mapCanvas && mapCanvas.clientWidth ? (mapCanvas.width / mapCanvas.clientWidth) : 1.0;
            const pixelRatioY = mapCanvas && mapCanvas.clientHeight ? (mapCanvas.height / mapCanvas.clientHeight) : 1.0;
            const anchorPoint = this.map.project({ lng: 0, lat: 0 });
            const anchorX = anchorPoint.x * pixelRatioX;
            const anchorY = anchorPoint.y * pixelRatioY;
            patternOffsetX = ((anchorX % patternScaleX) + patternScaleX) % patternScaleX;
            patternOffsetY = ((anchorY % patternScaleY) + patternScaleY) % patternScaleY;
        }

        gl.uniform2f(this.u_patternScaleLoc, patternScaleX, patternScaleY);
        gl.uniform2f(this.u_patternOffsetLoc, patternOffsetX, patternOffsetY);
        gl.uniform1f(this.u_viewportHeightLoc, gl.canvas.height);
        gl.uniform1f(this.u_opacityLoc, this.opacity);
        const dataCanvas = this.dataCanvas[this.getDataZoom()];
        gl.uniform2f(this.u_dataTexelLoc, 1 / dataCanvas.width, 1 / dataCanvas.height);

        gl.enable(gl.BLEND);
        gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);

        const dx = matrix[0];
        for (let i = -1; i <= 1; i++) {
            const m = matrix.slice();
            m[12] += i * dx;
            gl.uniformMatrix4fv(this.u_matrixLoc, false, m);
            gl.drawArrays(gl.TRIANGLE_STRIP, 0, this.vertexIds.length);
        }

        gl.activeTexture(gl.TEXTURE0);
    };

    return layer;
};

window.createFogOverlayLayer = createFogOverlayLayer;
