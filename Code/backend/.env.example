# ---- GEE Engine ----
BACKEND_GEE_ENABLED=true
# 32-byte hex key for encrypting stored GEE credentials (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BACKEND_GEE_CREDENTIALS_ENCRYPTION_KEY=
BACKEND_GEE_CREDENTIALS_DB_PATH=
BACKEND_GEE_STORAGE_BACKEND=local
BACKEND_GEE_LOCAL_STORAGE_ROOT=
# MinIO (only if BACKEND_GEE_STORAGE_BACKEND=minio)
BACKEND_GEE_MINIO_ENDPOINT=
BACKEND_GEE_MINIO_ACCESS_KEY=
BACKEND_GEE_MINIO_SECRET_KEY=
BACKEND_GEE_MINIO_BUCKET=gee-exports
BACKEND_GEE_MINIO_SECURE=false
# Account management
BACKEND_GEE_API_ACCOUNT_MANAGEMENT_ENABLED=true
BACKEND_GEE_ACCOUNT_COOLDOWN_SECONDS=300
# Parallel limits
BACKEND_GEE_MAX_PARALLEL_EXPORTS=2
BACKEND_GEE_MAX_PARALLEL_UPLOADS=4
BACKEND_GEE_MAX_PARALLEL_DOWNLOADS=4

# ---- Weather Engine ----
BACKEND_WEATHER_WORKFLOW_ENABLED=true
# Active-run capacity pools (business vs weather_tile workflows)
BACKEND_MAX_ACTIVE_RUNS=8
BACKEND_MAX_ACTIVE_WEATHER_TILE_RUNS=16
# Optional commercial weather providers (also configurable in Settings → Weather Providers).
# Providers register disabled by default until an API key is set and the provider is enabled.
# BACKEND_WEATHERAPI_API_KEY=
# BACKEND_OPENWEATHER_API_KEY=

# ---- Algorithm Data Roots ----
BACKEND_DATA_ROOT=
BACKEND_OUTPUT_ROOT=
BACKEND_PROJECTBACKUP_ROOT=

# ---- Remote storage (NAS SMB/SFTP) ----
# Same encryption key as GEE credentials (required outside development)
# BACKEND_GEE_CREDENTIALS_ENCRYPTION_KEY=
# Optional: short-timeout connectivity probe during layer readiness
BACKEND_REMOTE_READINESS_PROBE=false
# Max single-file download size in bytes (default 512MiB; raise for large HDF/GeoTIFF)
BACKEND_REMOTE_MAX_BYTES=536870912
# Prepend remote URIs to layer default_data_access_sources (JSON, one line)
# Example: {"smap-soil":{"SMAP_SPL3SMP_E":["smb://nas/share/SMAP/x.h5?cred=nas-lab"]}}
BACKEND_REMOTE_LAYER_DATA_URIS=
# History retention (encrypted previous secrets)
BACKEND_API_KEY_HISTORY_LIMIT=20
BACKEND_REMOTE_STORAGE_HISTORY_LIMIT=20
