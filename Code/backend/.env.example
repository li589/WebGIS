# ---- GEE Engine ----
BACKEND_GEE_ENABLED=true
# 32-byte hex key for encrypting stored GEE credentials (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BACKEND_GEE_CREDENTIALS_ENCRYPTION_KEY=
BACKEND_GEE_CREDENTIALS_DB_PATH=
BACKEND_GEE_STORAGE_BACKEND=local
BACKEND_GEE_LOCAL_STORAGE_ROOT=
# MinIO (only if BACKEND_GEE_STORAGE_BACKEND=minio)
BACKEND_GEE_MINIO_ENDPOINT=
BACKEND_GEE_MINIO_ACCESS_KEY=
BACKEND_GEE_MINIO_SECRET_KEY=
BACKEND_GEE_MINIO_BUCKET=gee-exports
BACKEND_GEE_MINIO_SECURE=false
# Account management
BACKEND_GEE_API_ACCOUNT_MANAGEMENT_ENABLED=true
BACKEND_GEE_ACCOUNT_COOLDOWN_SECONDS=300
# Parallel limits
BACKEND_GEE_MAX_PARALLEL_EXPORTS=2
BACKEND_GEE_MAX_PARALLEL_UPLOADS=4
BACKEND_GEE_MAX_PARALLEL_DOWNLOADS=4

# ---- Weather Engine ----
BACKEND_WEATHER_WORKFLOW_ENABLED=true
# Active-run capacity pools (business vs weather_tile workflows)
BACKEND_MAX_ACTIVE_RUNS=8
BACKEND_MAX_ACTIVE_WEATHER_TILE_RUNS=16

# ---- Algorithm Data Roots ----
BACKEND_DATA_ROOT=
BACKEND_OUTPUT_ROOT=
BACKEND_PROJECTBACKUP_ROOT=
