# ---- GEE Engine ----
BACKEND_GEE_ENABLED=true
# 32-byte hex key for encrypting stored GEE credentials (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BACKEND_GEE_CREDENTIALS_ENCRYPTION_KEY=
BACKEND_GEE_CREDENTIALS_DB_PATH=
BACKEND_GEE_STORAGE_BACKEND=local
BACKEND_GEE_LOCAL_STORAGE_ROOT=
# MinIO (only if BACKEND_GEE_STORAGE_BACKEND=minio)
BACKEND_GEE_MINIO_ENDPOINT=
BACKEND_GEE_MINIO_ACCESS_KEY=
BACKEND_GEE_MINIO_SECRET_KEY=
BACKEND_GEE_MINIO_BUCKET=gee-exports
BACKEND_GEE_MINIO_SECURE=false
# Account management
BACKEND_GEE_API_ACCOUNT_MANAGEMENT_ENABLED=true
BACKEND_GEE_ACCOUNT_COOLDOWN_SECONDS=300
# Parallel limits
BACKEND_GEE_MAX_PARALLEL_EXPORTS=2
BACKEND_GEE_MAX_PARALLEL_UPLOADS=4
BACKEND_GEE_MAX_PARALLEL_DOWNLOADS=4

# ---- Weather Engine ----
BACKEND_WEATHER_WORKFLOW_ENABLED=true
# Active-run capacity pools (business vs weather_tile workflows)
BACKEND_MAX_ACTIVE_RUNS=8
BACKEND_MAX_ACTIVE_WEATHER_TILE_RUNS=16
# Optional commercial weather providers (also configurable in Settings → Weather Providers).
# Providers register disabled by default until an API key is set and the provider is enabled.
# BACKEND_WEATHERAPI_API_KEY=
# BACKEND_OPENWEATHER_API_KEY=
# Self-hosted Open-Meteo API in backend compose (container: cgda-open-meteo).
# Sync jobs live in Code/infra/data-sync (-p data-sync), sharing volume backend_open-meteo-data.
# Start API: docker compose -p backend up -d
# Sync:      cd Code/infra/data-sync && .\sync.ps1   # or ./sync.sh
# Data:      Docker named volume inside Docker Desktop (this PC: I:\Docker\DockerDesktop).
BACKEND_OPEN_METEO_LOCAL_URL=http://127.0.0.1:8080/v1/forecast
BACKEND_OPEN_METEO_SYNC_COMPOSE_PROJECT=data-sync
# BACKEND_OPEN_METEO_SYNC_COMPOSE_DIR=   # default resolves to Code/infra/data-sync
# Self-hosted has no best_match; auto/best_match → this domain (must match open-meteo-sync)
# BACKEND_OPEN_METEO_LOCAL_MODEL=ecmwf_ifs025
# Legacy alias (same as LOCAL_URL for bootstrap):
# BACKEND_OPEN_METEO_URL=http://127.0.0.1:8080/v1/forecast

# ---- Algorithm Data Roots ----
BACKEND_DATA_ROOT=
BACKEND_OUTPUT_ROOT=
BACKEND_PROJECTBACKUP_ROOT=

# Static materialize cache (remote/http download nodes)
# Default: {python_provider_workspace}/data_access/materialized
# BACKEND_STATIC_CACHE_ROOT=
# TTL seconds; 0 = never expire (research-group static data policy)
BACKEND_STATIC_CACHE_TTL_SECONDS=0

# ---- Remote storage (NAS SMB/SFTP) ----
# Same encryption key as GEE credentials (required outside development)
# BACKEND_GEE_CREDENTIALS_ENCRYPTION_KEY=
# Optional: short-timeout connectivity probe during layer readiness
BACKEND_REMOTE_READINESS_PROBE=false
# Max single-file download size in bytes (default 512MiB; raise for large HDF/GeoTIFF)
BACKEND_REMOTE_MAX_BYTES=536870912
# Open portal tokens (optional; settings UI DB overlay preferred)
# BACKEND_EARTHDATA_TOKEN=
# BACKEND_NSIDC_TOKEN=
# BACKEND_COPERNICUS_TOKEN=
# Prepend remote URIs to layer default_data_access_sources (JSON, one line).
# Settings UI DB overlay overrides this env when both are set.
# Example (SMB): {"smap-soil":{"SMAP_SPL3SMP_E":["smb://nas/share/SMAP/x.h5?cred=nas-lab"]}}
# Example (local I: + Tools synthetic D2 set — adjust repo path):
# BACKEND_REMOTE_LAYER_DATA_URIS={"omega-avg-daily":{"omega_block_dir":["D:/temp_desktop/Proj/Comprehensive Geographic Data Analysis system/Tools/test_data/omega_avg_daily_inputs/omega_block"],"smap_folder":["I:/Geograph_DataSet/Soil_Ecological_Data/Smap_OriginData","D:/temp_desktop/Proj/Comprehensive Geographic Data Analysis system/Tools/test_data/omega_avg_daily_inputs/smap_daily"],"ndvi_folder":["D:/temp_desktop/Proj/Comprehensive Geographic Data Analysis system/Tools/test_data/omega_avg_daily_inputs/ndvi_daily"],"ndvi_clim_folder":["D:/temp_desktop/Proj/Comprehensive Geographic Data Analysis system/Tools/test_data/omega_avg_daily_inputs/ndvi_clim"],"anc_root":["D:/temp_desktop/Proj/Comprehensive Geographic Data Analysis system/Tools/test_data/omega_avg_daily_inputs/anc"]},"smap-soil":{"SMAP_SPL3SMP_E":["I:/Geograph_DataSet/SMAP"]},"ndvi":{"NDVI_16DAY_RASTER":["I:/Geograph_DataSet/Soil_Ecological_Data/NDVI/VIIRS_9km_tif"]}}
BACKEND_REMOTE_LAYER_DATA_URIS=
# History retention (encrypted previous secrets)
BACKEND_API_KEY_HISTORY_LIMIT=20
BACKEND_REMOTE_STORAGE_HISTORY_LIMIT=20
