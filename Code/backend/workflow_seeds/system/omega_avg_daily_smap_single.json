{
  "_meta": {
    "kind": "system",
    "engine": "python_provider",
    "name": "avg-ω 逐日反演（SMAP 单温度）",
    "description": "目的：D2 avg-omega 逐日反演主链路（SMAP TB + ORIG_TS 单温度方案）。前置：D1 omega_block 已产出 omega_block_*.mat + daily_omega/。产出：目标年逐日 SM/VOD/OMEGA .mat。配置：algorithm_params.target_year 指定目标年；avg_build_start_year/avg_build_end_year 指定 DOY 气候态构建年份范围。",
    "author": "system",
    "readonly": true,
    "is_template": true,
    "linked_layer_id": "omega-avg-daily"
  },
  "workflow_id": "omega_avg_daily_smap_single",
  "name": "avg-ω 逐日反演（SMAP 单温度）",
  "description": "D1 omega_block 输出 → D2 DOY 气候态 + 逐日 DDCA 回代（SMAP_SINGLE + ORIG_TS）。",
  "nodes": [
    {
      "id": 1,
      "type": "data/source",
      "pos": [80, 140],
      "properties": {
        "path": "InversionResults/omega_block",
        "dataset_key": "omega_block_output",
        "notes": "D1 omega_block 输出目录，需含 omega_block_{start}_{end}.mat 与 daily_omega/{date}.mat"
      }
    },
    {
      "id": 2,
      "type": "data/source",
      "pos": [80, 320],
      "properties": {
        "path": "Soil_Ecological_Data/Smap_OriginData",
        "dataset_key": "smap_daily_mat",
        "notes": "逐日 SMAP .mat（TBv/TBh/IA/Ts/vwc/SM），命名 YYYYMMDD.mat"
      }
    },
    {
      "id": 3,
      "type": "data/source",
      "pos": [80, 500],
      "properties": {
        "path": "SMAP_ancillary",
        "dataset_key": "ancillary_mat",
        "notes": "静态辅助库（IGBP_9km_12/Albedo/B/BD/CF/H/SF/NDVI_v_max/NDVI_v_min）"
      }
    },
    {
      "id": 4,
      "type": "data/source",
      "pos": [80, 680],
      "properties": {
        "path": "NDVI/daily",
        "dataset_key": "ndvi_daily_mat",
        "notes": "逐日 NDVI .mat（命名 YYYYMMDD.mat）；ndvi_clim_folder 指向 NDVI/climatology"
      }
    },
    {
      "id": 5,
      "type": "algorithm/omega_avg_daily",
      "pos": [520, 360],
      "properties": {
        "module_name": "omega_avg_daily",
        "task_type": "omega_avg_daily",
        "algorithm_params": {
          "target_year": 2023,
          "tb_source": "SMAP",
          "sm_source": "SMAP",
          "temp_scheme": "ORIG_TS",
          "ndvi_mode": "DAILY_FILE",
          "sf_mode": "STATIC",
          "avg_build_start_year": 2015,
          "avg_build_end_year": 2025,
          "freq_ghz": 1.4,
          "lambda_tau": 20.0,
          "pixel_chunk_size": 200000,
          "enable_parallel": true
        }
      }
    }
  ],
  "links": [
    {"0": 1, "1": 1, "2": 0, "3": 5, "4": 0, "5": "value:string"},
    {"0": 2, "1": 2, "2": 0, "3": 5, "4": 0, "5": "value:string"},
    {"0": 3, "1": 3, "2": 0, "3": 5, "4": 0, "5": "value:string"},
    {"0": 4, "1": 4, "2": 0, "3": 5, "4": 0, "5": "value:string"}
  ],
  "extra": {
    "purpose": "d2_avg_omega_daily",
    "scheme": "SMAP_SINGLE_ORIG_TS",
    "pipeline": "D1 omega_block → D2 DOY climatology → per-day DDCA (omega fixed = OMEGA_AVG)",
    "prerequisite": "D1 omega_block 必须先运行并产出 omega_block_*.mat + daily_omega/",
    "notes": "单温度方案用 Ts（SMAP 地表温度）；DOY 气候态从 avg_build_start_year~avg_build_end_year 的逐日 OMEGA 构建。"
  }
}
