{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "gen:types": "openapi-typescript ./openapi.json -o ./src/types/api-contracts.ts",
    "check:openapi": "python ../backend/scripts/check_openapi_drift.py",
    "lint": "eslint src",
    "lint:strict": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,js,jsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,js,jsx,css,scss}\""
  },
  "dependencies": {
    "@datapool/guangdong.geojson": "file:datapool-guangdong.geojson-1.0.1.tgz",
    "@types/papaparse": "^5.5.2",
    "@types/proj4": "^2.5.6",
    "cesium": "^1.142.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "litegraph.js": "^0.7.18",
    "maplibre-gl": "^5.24.0",
    "papaparse": "^5.5.4",
    "pinia": "^3.0.4",
    "proj4": "^2.20.9",
    "shpjs": "^6.2.0",
    "vue": "^3.5.34",
    "vue-cesium": "^3.2.12",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "openapi-typescript": "^7.5.0",
    "prettier": "^3.9.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}
